  <node componentName="tJavaFlex" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="1184" posY="64">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaFlex_1" show="false"/>
    <elementParameter field="CHECK" name="DATA_AUTO_PROPAGATE" value="true"/>
    <elementParameter field="MEMO_JAVA" name="CODE_START" value="// --- State (persist across rows) ---&#xA;java.util.HashMap&lt;Integer, Integer> dryDays =&#xA;  (java.util.HashMap&lt;Integer, Integer>) globalMap.get(&quot;DRY_DAYS_MAP&quot;);&#xA;&#xA;java.util.HashMap&lt;Integer, java.util.ArrayDeque&lt;Object[]>> precipWindow =&#xA;  (java.util.HashMap&lt;Integer, java.util.ArrayDeque&lt;Object[]>>) globalMap.get(&quot;PRECIP_WINDOW_MAP&quot;);&#xA;&#xA;java.util.HashMap&lt;Integer, Double> precipSum =&#xA;  (java.util.HashMap&lt;Integer, Double>) globalMap.get(&quot;PRECIP_SUM_MAP&quot;);&#xA;&#xA;if (dryDays == null) {&#xA;  dryDays = new java.util.HashMap&lt;>();&#xA;  globalMap.put(&quot;DRY_DAYS_MAP&quot;, dryDays);&#xA;}&#xA;if (precipWindow == null) {&#xA;  precipWindow = new java.util.HashMap&lt;>();&#xA;  globalMap.put(&quot;PRECIP_WINDOW_MAP&quot;, precipWindow);&#xA;}&#xA;if (precipSum == null) {&#xA;  precipSum = new java.util.HashMap&lt;>();&#xA;  globalMap.put(&quot;PRECIP_SUM_MAP&quot;, precipSum);&#xA;}&#xA;"/>
    <elementParameter field="MEMO_JAVA" name="CODE_MAIN" value="// 1) Copy input -> output (champ par champ)&#xA;outCalc.station_id = row3.station_id;&#xA;outCalc.date_jour = row3.date_jour;&#xA;&#xA;outCalc.temperature_max = row3.temperature_max;&#xA;outCalc.temperature_min = row3.temperature_min;&#xA;outCalc.temperature_moy = row3.temperature_moy;&#xA;outCalc.humidite_moyenne = row3.humidite_moyenne;&#xA;outCalc.precipitations_jour = row3.precipitations_jour;&#xA;outCalc.wind_speed_max = row3.wind_speed_max;&#xA;&#xA;outCalc.score_risque_max = row3.score_risque_max;&#xA;&#xA;// 2) radiation_solaire (source absente => valeur sûre)&#xA;outCalc.radiation_solaire = java.math.BigDecimal.ZERO;&#xA;&#xA;// 3) severity_label_max (0..3 -> libellé)&#xA;int sev = (row3.score_risque_max == null) ? 0 : row3.score_risque_max.intValue();&#xA;String sevLabel =&#xA;  (sev == 0) ? &quot;RAS&quot; :&#xA;  (sev == 1) ? &quot;Jaune&quot; :&#xA;  (sev == 2) ? &quot;Orange&quot; : &quot;Rouge&quot;;&#xA;outCalc.severity_label_max = sevLabel;&#xA;&#xA;// 4) jours_sans_pluie (compteur par station)&#xA;int station = row3.station_id;&#xA;double pday = (row3.precipitations_jour == null) ? 0.0 : row3.precipitations_jour.doubleValue();&#xA;&#xA;Integer prevDry = dryDays.get(station);&#xA;if (prevDry == null) prevDry = 0;&#xA;&#xA;int newDry = (pday &lt;= 0.0) ? (prevDry + 1) : 0;&#xA;dryDays.put(station, newDry);&#xA;outCalc.jours_sans_pluie = newDry;&#xA;&#xA;// 5) qualite_donnee (basée sur nulls des agrégats)&#xA;int missing = 0;&#xA;if (row3.temperature_max == null) missing++;&#xA;if (row3.temperature_min == null) missing++;&#xA;if (row3.temperature_moy == null) missing++;&#xA;if (row3.humidite_moyenne == null) missing++;&#xA;if (row3.wind_speed_max == null) missing++;&#xA;if (row3.precipitations_jour == null) missing++;&#xA;&#xA;String qual =&#xA;  (missing == 0) ? &quot;Excellente&quot; :&#xA;  (missing &lt;= 1) ? &quot;Bonne&quot; :&#xA;  (missing &lt;= 3) ? &quot;Moyenne&quot; : &quot;Faible&quot;;&#xA;outCalc.qualite_donnee = qual;&#xA;&#xA;// 6) idhc_30j (rolling 30 jours glissants, basé sur date_jour)&#xA;java.util.ArrayDeque&lt;Object[]> q = precipWindow.get(station);&#xA;if (q == null) {&#xA;  q = new java.util.ArrayDeque&lt;>();&#xA;  precipWindow.put(station, q);&#xA;}&#xA;Double sum = precipSum.get(station);&#xA;if (sum == null) sum = 0.0;&#xA;&#xA;// current day millis&#xA;long cur = row3.date_jour.getTime();&#xA;// threshold = cur - 29 jours (fenêtre 30 jours incluant aujourd'hui)&#xA;long threshold = cur - (29L * 24L * 60L * 60L * 1000L);&#xA;&#xA;// retirer les jours trop anciens&#xA;while (!q.isEmpty()) {&#xA;  Object[] head = q.peekFirst();&#xA;  long d = (Long) head[0];&#xA;  if (d &lt; threshold) {&#xA;    double pv = (Double) head[1];&#xA;    sum -= pv;&#xA;    q.removeFirst();&#xA;  } else {&#xA;    break;&#xA;  }&#xA;}&#xA;&#xA;// ajouter le jour courant&#xA;q.addLast(new Object[] { Long.valueOf(cur), Double.valueOf(pday) });&#xA;sum += pday;&#xA;&#xA;// sauvegarder&#xA;precipSum.put(station, sum);&#xA;&#xA;// idhc_30j >= 0&#xA;if (sum &lt; 0) sum = 0.0;&#xA;outCalc.idhc_30j = new java.math.BigDecimal(sum).setScale(2, java.math.RoundingMode.HALF_UP);&#xA;&#xA;// 7) score_risque (0..100) - simple et borné&#xA;double tmax = (row3.temperature_max == null) ? 0.0 : row3.temperature_max.doubleValue();&#xA;double hum  = (row3.humidite_moyenne == null) ? 50.0 : row3.humidite_moyenne.doubleValue();&#xA;double wind = (row3.wind_speed_max == null) ? 0.0 : row3.wind_speed_max.doubleValue();&#xA;double idhc = (outCalc.idhc_30j == null) ? 0.0 : outCalc.idhc_30j.doubleValue();&#xA;&#xA;// facteurs&#xA;double f_sech = Math.min(100.0, newDry * 5.0);&#xA;double f_chal = Math.max(0.0, Math.min(100.0, (tmax - 25.0) * 4.0));&#xA;double f_vent = Math.min(100.0, wind * 2.0);&#xA;double f_hum  = Math.max(0.0, Math.min(100.0, (60.0 - hum) * 1.5));&#xA;double protect_pluie = Math.min(40.0, idhc); // pluie réduit le risque&#xA;&#xA;double score = 0.35*f_sech + 0.30*f_chal + 0.20*f_vent + 0.15*f_hum - protect_pluie;&#xA;&#xA;// clamp 0..100&#xA;if (score &lt; 0) score = 0;&#xA;if (score > 100) score = 100;&#xA;&#xA;outCalc.score_risque = (int) Math.round(score);&#xA;&#xA;// 8) niveau_stress_hydrique (valeurs autorisées)&#xA;String stress;&#xA;if (newDry >= 14 || idhc &lt; 5) stress = &quot;Critique&quot;;&#xA;else if (newDry >= 7 || idhc &lt; 15) stress = &quot;Élevé&quot;;&#xA;else if (newDry >= 3 || idhc &lt; 30) stress = &quot;Modéré&quot;;&#xA;else stress = &quot;Normal&quot;;&#xA;&#xA;outCalc.niveau_stress_hydrique = stress;&#xA;&#xA;"/>
    <elementParameter field="MEMO_JAVA" name="CODE_END" value="// end of the component, outside/closing the loop&#xA;      "/>
    <elementParameter field="CHECK" name="Version_V2_0" value="false" show="false"/>
    <elementParameter field="CHECK" name="Version_V3_2" value="false" show="false"/>
    <elementParameter field="CHECK" name="Version_V4.0" value="true" show="false"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="outCalc"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJavaFlex_1">
